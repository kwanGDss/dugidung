# --- LLM 공급자 ---
# "openai" | "anthropic"  — 런타임에 어느 API 를 쓸지 선택
LLM_PROVIDER=openai

# OpenAI (기본: gpt-4o-mini, 변경하려면 OPENAI_MODEL 사용)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o           # 선택 — 기본은 gpt-4o-mini

# Anthropic (기본: claude-haiku-4-5-20251001, 변경하려면 ANTHROPIC_MODEL 사용)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # 선택 — 기본은 haiku 4.5

# --- Vercel KV (로컬 dev 에선 비워두면 in-memory fallback) ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- 배포 URL (OG 이미지 절대경로용) ---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- 카카오톡 공유 (없으면 카카오 버튼 자동 숨김) ---
# https://developers.kakao.com → 앱 생성 → JavaScript 키 복사
# 도메인 등록 필요 (플랫폼 > Web > 사이트 도메인에 http://localhost:3000 추가)
# NEXT_PUBLIC_KAKAO_APP_KEY=
